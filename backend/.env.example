# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=otp_service
DB_PORT=3306
DB_POOL_LIMIT=10

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# URLs
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_ADMIN_EXPIRE=30d

# Payment Gateway API Keys
TRIPAY_API_KEY=
TRIPAY_API_URL=https://api.tripay.co.id
TRIPAY_WEBHOOK_SECRET=

QRISPY_API_KEY=
QRISPY_API_URL=https://api.qrispy.id
QRISPY_WEBHOOK_SECRET=

# OTP Providers API Keys
FIVESIM_API_KEY=
FIVESIM_API_URL=https://api.5sim.net

HERO_SMS_API_KEY=
HERO_SMS_API_URL=https://api.herosms.com

NOKOSMURAH_API_KEY=
NOKOSMURAH_API_URL=https://api.nokosmurah.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logger Configuration
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Business Settings
OTP_EXPIRY_MINUTES=15
MIN_DEPOSIT_AMOUNT=10000
MAX_ACTIVE_ORDERS=5
OTP_CHECK_INTERVAL_SECONDS=15
DARK_MODE_ENABLED=true

# Affiliate Settings
AFFILIATE_COMMISSION_DEPOSIT=5
AFFILIATE_COMMISSION_ORDER=10